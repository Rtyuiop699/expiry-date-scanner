<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- معاينة الكاميرا (تظهر فقط داخل الإطار) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="320dp"
        android:layout_height="120dp"
        android:layout_gravity="center" />

    <!-- حدود الإطار الأخضر -->
    <!-- الخط العلوي -->
    <View
        android:layout_width="320dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginTop="-60dp"
        android:background="#00FF00" />

    <!-- الخط السفلي -->
    <View
        android:layout_width="320dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:background="#00FF00" />

    <!-- الخط الأيسر -->
    <View
        android:layout_width="3dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:layout_marginStart="-160dp"
        android:background="#00FF00" />

    <!-- الخط الأيمن -->
    <View
        android:layout_width="3dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:layout_marginStart="160dp"
        android:background="#00FF00" />

    <!-- زوايا الإطار -->
    <!-- الزاوية العلوية اليسرى -->
    <View
        android:layout_width="20dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginStart="-160dp"
        android:layout_marginTop="-60dp"
        android:background="#00FF00" />

    <View
        android:layout_width="3dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:layout_marginStart="-160dp"
        android:layout_marginTop="-60dp"
        android:background="#00FF00" />

    <!-- الزاوية العلوية اليمنى -->
    <View
        android:layout_width="20dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginStart="140dp"
        android:layout_marginTop="-60dp"
        android:background="#00FF00" />

    <View
        android:layout_width="3dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:layout_marginStart="160dp"
        android:layout_marginTop="-60dp"
        android:background="#00FF00" />

    <!-- الزاوية السفلية اليسرى -->
    <View
        android:layout_width="20dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginStart="-160dp"
        android:layout_marginTop="57dp"
        android:background="#00FF00" />

    <View
        android:layout_width="3dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:layout_marginStart="-160dp"
        android:layout_marginTop="40dp"
        android:background="#00FF00" />

    <!-- الزاوية السفلية اليمنى -->
    <View
        android:layout_width="20dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginStart="140dp"
        android:layout_marginTop="57dp"
        android:background="#00FF00" />

    <View
        android:layout_width="3dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:layout_marginStart="160dp"
        android:layout_marginTop="40dp"
        android:background="#00FF00" />

    <!-- النص الإرشادي -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="-100dp"
        android:text="ضع التاريخ داخل الإطار"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="#80000000"
        android:padding="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:letterSpacing="0.1" />

    <!-- الأزرار والنتائج في الأسفل -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/tvRecognizedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="سوف يظهر النص المكتشف هنا"
            android:padding="12dp"
            android:background="#F0F0F0"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTakePicture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📸 تصوير"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btnUseDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✅ استخدام التاريخ"
                android:enabled="false"
                android:backgroundTint="#2196F3" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
