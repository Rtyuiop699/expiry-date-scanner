<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:layoutDirection="rtl">

    <!-- الشريط العلوي الأخضر -->
     <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/topAppBar"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@drawable/toolbar_border"
    
    android:elevation="0dp"
    app:navigationIcon="@drawable/icarrowback"
    app:title="إضافة منتج"
    app:titleTextColor="#000000"
    app:menu="@menu/addproductmenu" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- الحاوية الرئيسية لكل العناصر -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- القسم الأول: الأزرار والصورة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginBottom="16dp">

        <!-- حاوية الأزرار (يسار الصورة) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="12dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnCaptureImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="التقاط صورة"/>

            <Button
                android:id="@+id/btnChooseImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اختيار صورة"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- الصورة (يمين الشاشة) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="150dp"
            android:layout_height="150dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            
            <ImageView
                android:id="@+id/imageViewProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" 
                android:background="#DDDDDD"
                android:src="@android:drawable/ic_menu_camera"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- القسم الثاني: حقل التصنيف المنسدل وزر الإضافة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/menuCategories"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="التصنيف">

            <AutoCompleteTextView
                android:id="@+id/autoCompleteCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" 
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- زر الإضافة (مربع صغير بجانب الحقل) -->
        <Button
            android:id="@+id/btnAddCategory"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="55dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+"
            android:textSize="20sp" />
    </LinearLayout>

</LinearLayout>
    

            <!-- اسم المنتج + أيقونة خارج الحقل -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="اسم المنتج"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- أيقونة الاسم (خارج الحقل) -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ictagred"
                    android:layout_marginStart="8dp"
                    android:tint="#F44336"/>
            </LinearLayout>

            <!-- الباركود + أيقونة خارج الحقل -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="رمز الباركود"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextBarcode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- أيقونة الباركود (خارج الحقل - خطوط أسود/أبيض) -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/icbarcode"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
<!-- التاريخ + الأيقونة -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginTop="16dp">

    <!-- حقل التاريخ -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="تاريخ الانتهاء"
        app:boxBackgroundMode="outline">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 👇 الأيقونة هنا (خارج الحقل) -->
    <ImageView
        android:id="@+id/btnOpenCalendar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/iccalendar"
        android:layout_marginStart="8dp"
        android:tint="#4CAF50"/>
</LinearLayout>
   <!-- الكمية (كرتون / باكت / حبة) -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <!-- الصف الأول: العناوين -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">

                    <TextView
                        android:text="كرتون"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="باكت في الكرتون"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="حبة في الباكت"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- الصف الثاني: حقول الإدخال -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/editCarton"
                        android:hint="عدد الكراتين"
                        android:inputType="number"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/editPack"
                        android:hint="عدد الباكت"
                        android:inputType="number"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/editPiece"
                        android:hint="عدد الحبات"
                        android:inputType="number"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- زر يوجد باكت -->
                <Button
                    android:id="@+id/btnHasPack"
                    android:text="يوجد باكت ✔️"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"/>

                <!-- زر احسب + حقل النتيجة -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btnCalculate"
                        android:text="احسب"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/editResult"
                        android:hint="النتيجة"
                        android:enabled="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>         
        </LinearLayout>
    
    </ScrollView>

</LinearLayout>
